{
  "name": "simple-newsvendor-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node --test 'tests/server/**/*.test.js'",
    "test:ui": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "supertest": "^7.1.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.101.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
